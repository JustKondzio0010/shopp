{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/leather_helmet"
    },
    "cases": [
      {
        "when": "1",
        "model": {
          "type": "minecraft:model",
          "model": "shine_oni:shine_onihelmet"
        }
      },
      {
        "when": "2",
        "model": {
          "type": "minecraft:model",
          "model": "skulpt:compendiums/platinum_compendium/platinum_helmet"
        }
      }
    ]
  }
}